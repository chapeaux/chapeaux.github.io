    "purple-40": { "$value": "#876fd4" },
    "purple-60": { "$value": "#3d2785" },
    "purple-70": { "$value": "#21134d" },
    "purple-80": { "$value": "#1b0d33" },
    "blue-10": { "$value": "#e0f0ff" },
    "blue-20": { "$value": "#b9dafc" },
