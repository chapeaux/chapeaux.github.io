{
  "color-critical": {
    "$type": "color",
    "$description": "Core brand colors — inlined in <head>",
    "red-50": { "$value": "#ee0000", "$description": "Red Hat Red" },
    "white": { "$value": "#ffffff" },
    "black": { "$value": "#151515" },
    "gray-lightest": { "$value": "#f5f5f5" },
    "gray-light": { "$value": "#e7e7e7" },
    "gray": { "$value": "#6a6e73" },
    "gray-dark": { "$value": "#3c3f42" },
    "orange": { "$value": "#f5921b" },
    "teal": { "$value": "#37a3a3" },
    "blue": { "$value": "#0066cc" },
    "dark-blue": { "$value": "#003366" },
    "purple": { "$value": "#5e40be" },
    "yellow": { "$value": "#ffcc17" }
  },
  "surface-critical": {
    "$type": "color",
    "$description": "Semantic surface colors — inlined in <head>",
    "background": {
      "on": {
        "light": { "$value": "{color-critical.white}" },
        "dark": { "$value": "{color.gray-90}" }
      }
    },
    "surface": {
      "on": {
        "light": { "$value": "{color-critical.gray-lightest}" },
        "dark": { "$value": "{color.gray-80}" }
      }
    },
    "text": {
      "on": {
        "light": { "$value": "{color-critical.black}" },
        "dark": { "$value": "{color.gray-20}" }
      }
    },
    "text-muted": {
      "on": {
        "light": { "$value": "{color-critical.gray}" },
        "dark": { "$value": "{color.gray-40}" }
      }
    },
    "border": {
      "on": {
        "light": { "$value": "{color-critical.gray-light}" },
        "dark": { "$value": "{color.gray-70}" }
      }
    },
    "code-bg": {
      "on": {
        "light": { "$value": "{color-critical.gray-lightest}" },
        "dark": { "$value": "{color.gray-90}" }
      }
    },
    "header-bg": {
      "on": {
        "light": { "$value": "{color-critical.white}" },
        "dark": { "$value": "{color.gray-95}" }
      }
    }
  },
  "color": {
    "$type": "color",
    "$description": "Extended palette — deferred CSS",
    "red-05": { "$value": "#fef0f0" },
    "red-10": { "$value": "#fce3e3" },
