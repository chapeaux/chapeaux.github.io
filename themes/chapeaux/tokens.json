    "orange-60": { "$value": "#9e4a06" },
    "orange-70": { "$value": "#732e00" },
    "orange-80": { "$value": "#4d1f00" },
    "yellow-10": { "$value": "#fff4cc" },
    "yellow-20": { "$value": "#ffe072" },
    "yellow-40": { "$value": "#dca614" },
    "yellow-50": { "$value": "#b98412" },
    "yellow-60": { "$value": "#96640f" },
    "yellow-70": { "$value": "#73480b" },
    "yellow-80": { "$value": "#54330b" },
    "teal-10": { "$value": "#daf2f2" },
    "teal-20": { "$value": "#b9e5e5" },
    "teal-30": { "$value": "#9ad8d8" },
