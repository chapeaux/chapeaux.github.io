    "red-80": { "$value": "#3f0000" },
    "gray-10": { "$value": "#f2f2f2" },
    "gray-20": { "$value": "#e0e0e0" },
    "gray-30": { "$value": "#c7c7c7" },
    "gray-40": { "$value": "#a3a3a3" },
    "gray-45": { "$value": "#8c8c8c" },
    "gray-50": { "$value": "#707070" },
    "gray-60": { "$value": "#4d4d4d" },
