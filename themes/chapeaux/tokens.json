  "stage": {
    "$type": "color",
    "$description": "Project stage colors",
    "develop": { "$value": "{color-critical.teal}" },
    "discover": { "$value": "{color-critical.blue}" },
    "deliver": { "$value": "{color-critical.purple}" }
  },
  "typography-critical": {
    "$description": "Font families — critical for first paint",
    "heading": {
      "$type": "fontFamily",
      "$value": "'Oswald', sans-serif"
    },
    "body": {
      "$type": "fontFamily",
      "$value": "'Red Hat Text', sans-serif"
    }
  },
  "spacing": {
    "$type": "dimension",
    "$description": "Spacing scale",
    "xs": { "$value": { "value": 0.25, "unit": "rem" } },
    "sm": { "$value": { "value": 0.5, "unit": "rem" } },
    "md": { "$value": { "value": 1, "unit": "rem" } },
    "lg": { "$value": { "value": 2, "unit": "rem" } },
    "xl": { "$value": { "value": 4, "unit": "rem" } }
  },
  "layout": {
    "$type": "dimension",
    "$description": "Layout dimensions",
    "max-width": { "$value": { "value": 1200, "unit": "px" } },
    "nav-height": { "$value": { "value": 64, "unit": "px" } }
  }
}
